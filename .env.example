# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD
POSTGRES_DB=transcendence

# ── URLs ──────────────────────────────────────────────────────────────────────
# Use /api for the Vite dev server proxy or full URL for external access
VITE_API_URL=/api
REACT_APP_API_URL=http://localhost:5000/api
FRONTEND_URL=http://localhost:5173

# ── Backend (NestJS) ──────────────────────────────────────────────────────────
NODE_ENV=development
# Set DB_HOST to 'db' for Docker, or 'localhost' for local development
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ── OAuth / Auth ─────────────────────────────────────────────────────────────
FORTY_TWO_CLIENT_ID=your_42_client_id
FORTY_TWO_CLIENT_SECRET=your_42_client_secret
FORTY_TWO_CALLBACK_URL=http://localhost:5000/api/auth/42/callback

GOOGLE_CLIENT_ID=placeholder_google_client_id
GOOGLE_CLIENT_SECRET=placeholder_google_client_secret

JWT_SECRET=super_secret_jwt_key_here
